# ─────────────────────────────────────────────────────────────
# BananaShop CTF — variables d'environnement
# Copiez ce fichier en .env et ajustez les valeurs.
# ─────────────────────────────────────────────────────────────

# ── Dashboard ─────────────────────────────────────────────────
ADMIN_PASSWORD=admin
HINT_PENALTY=5
EVENT_TITLE=BananaShop CTF

# ── Build frontend (préfixe VITE_ obligatoire) ────────────────
VITE_NANTES_HACK=1              # 1 = branding Nantes@Hack activé
VITE_PROGRESSIVE_UNLOCK=false   # true = niveaux débloqués progressivement
VITE_UNLOCK_THRESHOLD=2         # challenges à résoudre pour passer au niveau suivant

# ── Équipes ───────────────────────────────────────────────────
TEAM1_NAME=Alpha
TEAM1_PASSWORD=aco45

TEAM2_NAME=Bravo
TEAM2_PASSWORD=etd15

TEAM3_NAME=Charlie
TEAM3_PASSWORD=oit56

TEAM4_NAME=Delta
TEAM4_PASSWORD=aqd59
